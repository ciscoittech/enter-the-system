    style LOAD fill:#BBDEFB,stroke:#1976D2
    style CLAUDE fill:#7E57C2,stroke:#512DA8,color:#fff
    style EXT fill:#A5D6A7,stroke:#4CAF50
    style HOOKCHECK fill:#FFC107,stroke:#F9A825,stroke-width:2px
    style OUTPUT fill:#4CAF50,stroke:#2E7D32,color:#fff
    style REDO fill:#EF5350,stroke:#C62828,color:#fff
    style UPDATE fill:#8BC34A,stroke:#558B2F,color:#fff
