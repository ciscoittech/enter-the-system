---
title: "PII Redactor: Three-Tier Decision Logic"
---
flowchart TD
    INPUT["Sensitive data detected"]

    INPUT --> T1
    INPUT --> T2
    INPUT --> T3

    subgraph T1["PRESERVE — Keep As-Is"]
        direction TB
        P1["Private IPs\n(192.168.x.x, 10.0.x.x)"]
        P2["Vendor domains\n(cisco.com, juniper.net)"]
        P_WHY["WHY: Needed for analysis\nor already public knowledge"]
        P1 --- P_WHY
        P2 --- P_WHY
    end

    subgraph T2["MAP — Replace Reversibly"]
        direction TB
        M1["Public IPs → 10.99.x.x"]
        M2["Hostnames → device-1, device-2"]
        M3["Customer names → Customer-1"]
        M4["SNMP communities → community1"]
        M_WHY["WHY: Hide identity but\nmaintain relationships.\nToken store enables restoration."]
        M1 --- M_WHY
        M2 --- M_WHY
        M3 --- M_WHY
        M4 --- M_WHY
    end

    subgraph T3["DESTROY — Non-Recoverable"]
        direction TB
        D1["Passwords"]
        D2["API keys"]
        D3["Secrets & auth tokens"]
        D_WHY["WHY: Too dangerous in any form.\n→ [REDACTED] with no way back."]
        D1 --- D_WHY
        D2 --- D_WHY
        D3 --- D_WHY
    end

    T1 --> OUT1["Data passes through unchanged"]
    T2 --> OUT2["Token store holds\nbidirectional mapping\n(original ↔ replacement)"]
    T3 --> OUT3["Original value\npermanently discarded"]

    style INPUT fill:#f5f5f5,stroke:#333,stroke-width:2px

    style T1 fill:#E8F5E9,stroke:#2E7D32,stroke-width:2px
    style P1 fill:#4CAF50,stroke:#2E7D32,color:#fff
    style P2 fill:#4CAF50,stroke:#2E7D32,color:#fff
    style P_WHY fill:#C8E6C9,stroke:#2E7D32,font-style:italic

    style T2 fill:#FFF3E0,stroke:#E65100,stroke-width:2px
    style M1 fill:#FFB74D,stroke:#E65100
    style M2 fill:#FFB74D,stroke:#E65100
    style M3 fill:#FFB74D,stroke:#E65100
    style M4 fill:#FFB74D,stroke:#E65100
    style M_WHY fill:#FFE0B2,stroke:#E65100,font-style:italic

    style T3 fill:#FFEBEE,stroke:#C62828,stroke-width:2px
    style D1 fill:#EF5350,stroke:#C62828,color:#fff
    style D2 fill:#EF5350,stroke:#C62828,color:#fff
    style D3 fill:#EF5350,stroke:#C62828,color:#fff
    style D_WHY fill:#FFCDD2,stroke:#C62828,font-style:italic

    style OUT1 fill:#A5D6A7,stroke:#4CAF50
    style OUT2 fill:#FFE0B2,stroke:#E65100
    style OUT3 fill:#FFCDD2,stroke:#E53935
